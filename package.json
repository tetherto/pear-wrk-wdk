{
  "name": "@tetherto/pear-wrk-wdk",
  "version": "1.0.0-beta.6",
  "main": "index.js",
  "scripts": {
    "build:types": "tsc --noEmit",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "node --test test/**/*.test.js",
    "test:watch": "node --test --watch test/**/*.test.js",
    "gen:hrpc": "node scripts/generate-hrpc.js",
    "gen:schema": "npm run gen:hrpc",
    "prepare": "npm run gen:hrpc"
  },
  "files": [
    "index.js",
    "worklet.js",
    "src",
    "types",
    "generated",
    "package.json",
    "README.md"
  ],
  "dependencies": {
    "@scure/bip39": "^1.6.0",
    "hrpc": "^4.0.1",
    "hyperschema": "^1.12.4"
  },
  "devDependencies": {
    "bare-ipc": "^1.1.1",
    "rimraf": "6.0.1",
    "standard": "17.1.2",
    "typescript": "5.8.3"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./index.js"
    },
    "./worklet": {
      "types": "./types/index.d.ts",
      "default": "./worklet.js"
    },
    "./package.json": "./package.json",
    "./hrpc": {
      "types": "./types/hrpc/hrpc.d.ts",
      "default": "./generated/hrpc/index.js"
    }
  },
